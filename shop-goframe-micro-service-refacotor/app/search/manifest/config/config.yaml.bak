server:
  address: ":8499"
  openapiPath: "/api.json"
  swaggerPath: "/swagger"
  logger:
    path: "./log"
    file: "{Y-m-d}.log"
    prefix: "search-service"
    level: "all"
    stdout: true
    rotateSize: 104857600
    rotateBackupLimit: 7
    ctxKeys: [ "traceId" ]
    timeFormat: "2006-01-02 15:04:05.000"

database:
  default:
    link:  "mysql:root:root@tcp(127.0.0.1:3306)/goods"
    debug:

etcd:
  address: "127.0.0.1:2379"

elasticsearch:
  address: "http://127.0.0.1:9200"
  sniff: false
  healthcheck: true
  indices:
    goods: "mall_goods"

binlog:
  goods:
    mysql:
      host: "127.0.0.1"
      port: 3306
      username: "root"
      password: "root"
