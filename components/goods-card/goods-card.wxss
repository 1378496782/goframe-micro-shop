.goods-card {
  display: flex;
  padding: 12px;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.goods-image {
  width: 100px;
  height: 100px;
  border-radius: 6px;
  margin-right: 12px;
  background: linear-gradient(135deg, #f5f5f5 25%, #e8e8e8 50%, #f5f5f5 75%);
  background-size: 400% 400%;
  animation: shimmer 1.5s ease-in-out infinite;
  transition: opacity 0.3s ease;
}

.goods-image.loaded {
  animation: none;
  background: transparent;
}

.goods-image.error {
  background: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goods-image.error::before {
  content: "图片加载失败";
  color: #999;
  font-size: 12px;
}

@keyframes shimmer {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: -100% 0;
  }
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.goods-brand {
  font-size: 12px;
  color: #666;
  background: #f5f5f5;
  padding: 2px 6px;
  border-radius: 4px;
}

.goods-sale {
  font-size: 12px;
  color: #999;
}

.goods-price-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 16px;
  font-weight: bold;
  color: #ff6b00;
}

.goods-stock {
  font-size: 12px;
  color: #666;
}