<!-- 商品图片轮播 -->
<view class="product-gallery">
  <image src="{{currentImage}}" mode="aspectFit" class="main-image" />
  <scroll-view class="thumbnail-list" scroll-x="true">
    <image 
      wx:for="{{product.images}}" 
      wx:key="index" 
      src="{{item}}" 
      class="thumbnail {{currentImageIndex === index ? 'active' : ''}}"
      bindtap="selectImage" 
      data-index="{{index}}"
    />
  </scroll-view>
</view>

<!-- 商品信息 -->
<view class="product-info">
  <view class="price-section">
    <text class="current-price">¥{{product.price}}</text>
    <text class="original-price">¥{{product.originalPrice}}</text>
    <text class="discount">{{product.discount}}折</text>
  </view>
  
  <text class="product-title">{{product.name}}</text>
  
  <view class="sales-info">
    <text>销量: {{product.sales}}件</text>
    <text>评价: {{product.reviews}}条</text>
    <text>库存: {{product.stock}}件</text>
  </view>
</view>

<!-- 规格选择 -->
<view class="spec-section">
  <text class="section-title">选择规格</text>
  <view class="spec-options">
    <view class="spec-item" wx:for="{{product.specs}}" wx:key="name">
      <text class="spec-name">{{item.name}}</text>
      <view class="spec-values">
        <text 
          wx:for="{{item.values}}" 
          wx:key="*this" 
          class="spec-value {{selectedSpecs[item.name] === item ? 'active' : ''}}"
          bindtap="selectSpec" 
          data-spec-name="{{item.name}}" 
          data-value="{{item}}"
        >
          {{item}}
        </text>
      </view>
    </view>
  </view>
</view>

<!-- 商品详情 -->
<view class="product-description">
  <text class="section-title">商品详情</text>
  <view class="description-content">
    <text>【旗舰性能】搭载最新处理器，流畅运行各种应用</text>
    <text>【超清显示】6.7英寸OLED屏幕，色彩鲜艳</text>
    <text>【长续航】5000mAh大电池，支持快充</text>
    <text>【高清相机】4800万像素主摄，夜景更清晰</text>
  </view>
</view>

<!-- 底部操作栏 -->
<view class="action-bar">
  <view class="action-left">
    <button class="action-btn" bindtap="addToFavorites">
      <text>❤️</text>
      <text>收藏</text>
    </button>
    <button class="action-btn" bindtap="goToCart">
      <text>🛒</text>
      <text>购物车</text>
    </button>
  </view>
  <view class="action-right">
    <button class="add-cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="buy-now-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>