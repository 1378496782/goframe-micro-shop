<!-- 加载状态 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 商品图片 -->
<view class="product-gallery" wx:if="{{!loading && product}}">
  <image src="{{product.images[0]}}" mode="aspectFit" class="main-image" />
</view>

<!-- 商品信息 -->
<view class="product-info" wx:if="{{!loading && product}}">
  <view class="price-section">
    <text class="current-price">¥{{product.price}}</text>
    <text class="original-price">¥{{product.originalPrice}}</text>
    <text class="discount">{{product.discount}}折</text>
  </view>
  
  <text class="product-title">{{product.name}}</text>
  
  <view class="sales-info">
    <text>销量: {{product.sale}}件</text>
    <text>库存: {{product.stock}}件</text>
  </view>
</view>

<!-- 规格选择 -->
<view class="spec-section" wx:if="{{!loading && product}}">
<!--  <text class="section-title">商品信息</text> -->
  <view class="spec-options">
  <!--  <view class="spec-item">
      <text class="spec-name">商品名称</text>
      <view class="spec-values">
        <text class="spec-value active">{{product.name}}</text>
      </view>
    </view> -->
    <view class="spec-item" wx:if="{{product.brand}}">
      <text class="spec-name">品牌</text>
      <view class="spec-values">
        <text class="spec-value active">{{product.brand}}</text>
      </view>
    </view>
    <view class="spec-item" wx:if="{{product.tags}}">
      <text class="spec-name">标签</text>
      <view class="spec-values">
        <text class="spec-value active">{{product.tags}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 商品详情 -->
<view class="product-description" wx:if="{{!loading && product}}">
  <text class="section-title">商品详情</text>
  <view class="description-content">
    <block wx:for="{{product.images}}" wx:key="*this">
      <image src="{{item}}" mode="widthFix" style="width:100%;margin-bottom:20rpx;" />
    </block>
  </view>
</view>



<!-- 底部操作栏 -->
<view class="action-bar" wx:if="{{!loading && product}}">
  <view class="action-left">
    <button class="action-btn" bindtap="addToFavorites">
      <text>❤️</text>
      <text>收藏</text>
    </button>
    <button class="action-btn" bindtap="goToCart">
      <text>🛒</text>
      <text>购物车</text>
    </button>
  </view>
  <view class="action-right">
    <button class="add-cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="buy-now-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>