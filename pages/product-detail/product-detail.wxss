.product-gallery {
  background: white;
  padding: 15px;
}

.main-image {
  width: 100%;
  height: 300px;
  margin-bottom: 15px;
}

.thumbnail-list {
  display: flex;
  gap: 10px;
}

.thumbnail {
  width: 60px;
  height: 60px;
  border: 2px solid #ddd;
  border-radius: 6px;
}

.thumbnail.active {
  border-color: #19aecc;
}

.product-info {
  background: white;
  padding: 15px;
  margin-top: 10px;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 15px;
}

.current-price {
  font-size: 24px;
  color: #F53F3F;
  font-weight: bold;
}

.original-price {
  font-size: 16px;
  color: #86909C;
  text-decoration: line-through;
}

.discount {
  background: #F53F3F;
  color: white;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.product-title {
  font-size: 18px;
  color: #1D2129;
  margin: 0 0 15px 0;
  line-height: 1.4;
}

.sales-info {
  display: flex;
  gap: 15px;
  font-size: 12px;
  color: #86909C;
}

.spec-section {
  background: white;
  padding: 15px;
  margin-top: 10px;
}

.section-title {
  margin: 0 0 15px 0;
  font-size: 16px;
  color: #1D2129;
  display: block;
}

.spec-item {
  margin-bottom: 20px;
}

.spec-name {
  margin: 0 0 10px 0;
  font-size: 14px;
  color: #4E5969;
  display: block;
}

.spec-values {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.spec-value {
  padding: 8px 15px;
  border: 1px solid #ddd;
  border-radius: 20px;
  font-size: 12px;
}

.spec-value.active {
  border-color: #19aecc;
  color: #19aecc;
  background: #e6f7ff;
}

.product-description {
  background: white;
  padding: 15px;
  margin-top: 10px;
}

.description-content {
  font-size: 14px;
  color: #4E5969;
  line-height: 1.6;
}

.description-content text {
  display: block;
  margin-bottom: 8px;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 10px 15px;
  border-top: 1px solid #f0f0f0;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0 15px;
  font-size: 12px;
  color: #4E5969;
}

.action-btn::after {
  border: none;
}

.action-right {
  display: flex;
  flex: 1;
  justify-content: flex-end;
  gap: 10px;
}

.add-cart-btn {
  background: #FFB300;
  color: white;
  border: none;
  padding: 12px 20px;
  border-radius: 20px;
  font-size: 14px;
}

.buy-now-btn {
  background: #19aecc;
  color: white;
  border: none;
  padding: 12px 20px;
  border-radius: 20px;
  font-size: 14px;
}

.add-cart-btn::after,
.buy-now-btn::after {
  border: none;
}