<view class="container">
  <!-- 购物车为空状态 -->
  <view class="empty-cart" wx:if="{{cartItems.length === 0}}">
    <image src="/images/empty-cart.png" class="empty-icon" />
    <text class="empty-text">购物车空空如也</text>
    <button class="browse-btn" bindtap="goToIndex">去逛逛</button>
  </view>

  <!-- 购物车商品列表 -->
  <view class="cart-list" wx:else>
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <view class="item-left">
        <checkbox checked="{{item.selected}}" bindtap="toggleSelect" data-index="{{index}}"/>
        <image src="{{item.image}}" class="item-image" />
      </view>
      
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-spec">{{item.spec}}</text>
        <view class="price-section">
          <text class="current-price">¥{{item.price}}</text>
          <text class="original-price">¥{{item.originalPrice}}</text>
        </view>
        
        <view class="quantity-control">
          <button class="btn-minus" bindtap="decreaseQuantity" data-index="{{index}}">-</button>
          <text class="quantity">{{item.quantity}}</text>
          <button class="btn-plus" bindtap="increaseQuantity" data-index="{{index}}">+</button>
        </view>
      </view>
      
      <button class="btn-delete" bindtap="deleteItem" data-index="{{index}}">删除</button>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="settlement-bar" wx:if="{{cartItems.length > 0}}">
    <view class="select-all">
      <checkbox checked="{{allSelected}}" bindtap="toggleSelectAll"/>
      <text>全选</text>
    </view>
    
    <view class="total-info">
      <text>合计: ¥{{totalPrice}}</text>
      <text>已选{{selectedCount}}件</text>
    </view>
    
    <button class="settle-btn" bindtap="goToSettlement">去结算</button>
  </view>
</view>