.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 60rpx;
}

.form {
  padding: 40rpx 30rpx;
}

.input-group {
  margin-bottom: 40rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.label {
  display: block;
  padding: 30rpx 0 20rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input {
  height: 80rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}

.input:last-child {
  border-bottom: none;
}

.submit-btn {
  margin-top: 60rpx;
  background-color: #19aecc;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.submit-btn:active {
  background-color: #158ea8;
}