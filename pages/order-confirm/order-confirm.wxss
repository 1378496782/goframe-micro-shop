/* 容器样式 */
.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 120rpx; /* 为底部操作栏留出空间 */
}

/* 商品列表 */
.goods-list {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
  border-left: 6rpx solid #19aecc;
  padding-left: 20rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.goods-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: #f8f8f8;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.4;
  font-weight: 500;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.goods-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

/* 优惠券选择 */
.coupon-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.coupon-select {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.coupon-text {
  font-size: 28rpx;
  color: #333;
}

.coupon-arrow {
  font-size: 36rpx;
  color: #999;
}

.coupon-cancel-btn {
  margin-top: 15rpx;
  padding: 15rpx 20rpx;
  background: #fff5f5;
  border-radius: 8rpx;
  border: 1rpx solid #ffe0e0;
  text-align: center;
}

.cancel-text {
  font-size: 26rpx;
  color: #e64340;
}

/* 备注区域 */
.remark-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
  border-left: 6rpx solid #19aecc;
  padding-left: 20rpx;
  position: relative;
}

.required-mark {
  color: #e64340;
  margin-left: 8rpx;
  font-weight: bold;
}

.remark-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
  font-weight: normal;
}

.remark-input {
  width: 100%;
  height: 120rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #eee;
  transition: border-color 0.3s;
}

.remark-input.error {
  border-color: #e64340;
  background: #fff5f5;
}

.error-message {
  color: #e64340;
  font-size: 24rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.placeholder {
  color: #ccc;
}

/* 价格区域 */
.price-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.price-item.total {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.price {
  color: #e64340;
  font-weight: bold;
}

.price.total {
  font-size: 36rpx;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.total-price {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.total-price .price {
  font-size: 32rpx;
  color: #e64340;
}

.submit-btn {
  background: #19aecc;
  color: white;
  border-radius: 40rpx;
  padding: 0 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
}

.submit-btn.loading {
  background: #19aecc;
  opacity: 0.7;
}

/* 优惠券弹窗 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.coupon-popup {
  background: white;
  border-radius: 16rpx;
  width: 80%;
  max-height: 50vh; /* 降低弹窗高度，使其更加协调 */
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-close {
  font-size: 40rpx;
  color: #999;
}

.coupon-list {
  max-height: 35vh; /* 降低滚动区域高度，与弹窗高度匹配 */
  padding: 20rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx; /* 减少内边距，使项目更紧凑 */
  margin-bottom: 15rpx; /* 减少项目间距 */
  background: #f8f8f8;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.coupon-item.selected {
  border-color: #19aecc;
  background: #e6f7ff;
}

.coupon-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #e64340;
  margin-right: 20rpx;
  min-width: 120rpx;
}

.coupon-info {
  flex: 1;
}

.coupon-desc {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.coupon-expire {
  font-size: 24rpx;
  color: #999;
}

.empty-coupon {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.popup-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  background: #f8f8f8;
}

.cancel-coupon-btn {
  width: 100%;
  background: #f5f5f5;
  color: #666;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #ddd;
}

.cancel-coupon-btn:active {
  background: #e8e8e8;
}

/* 阻止事件冒泡 */
.stopPropagation {
  /* 空样式，用于阻止事件冒泡 */
}

/* 推荐商品区域 */
.recommend-section {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 15rpx;
  gap: 15rpx;
  position: relative;
}

.recommend-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.recommend-info {
  flex: 1;
  min-width: 0;
}

.recommend-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recommend-price {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 10rpx;
}

.current-price {
  font-size: 26rpx;
  color: #e64340;
  font-weight: bold;
}

.original-price {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
}

.add-btn {
  height: 44rpx;
  line-height: 44rpx;
  font-size: 22rpx;
  background: linear-gradient(135deg, #19aecc, #1bc2e3);
  color: white;
  border-radius: 22rpx;
  padding: 0 20rpx;
  margin: 0;
  border: none;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(25, 174, 204, 0.3);
  transition: all 0.3s ease;
  font-weight: 500;
}

.add-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(25, 174, 204, 0.3);
}

/* 推荐商品勾选框样式 */
.recommend-checkbox {
  transform: scale(1.2);
  margin-right: 10rpx;
}

.recommend-checkbox .wx-checkbox-input {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
}

.recommend-checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: #19aecc;
  border-color: #19aecc;
}

.recommend-checkbox .wx-checkbox-input.wx-checkbox-input-checked::before {
  content: '✓';
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 36rpx;
  text-align: center;
}

/* 推荐商品价格项样式 */
.price-item.recommend-item {
  color: #666;
  font-size: 24rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #19aecc;
  margin: 10rpx 0;
}

.price-item.recommend-item .price {
  color: #e64340;
  font-weight: bold;
}