<view class="login-container">
  <!-- 头部标题 -->
  <view class="header">
    <text class="title">欢迎登录</text>
    <text class="subtitle">请使用手机号登录您的账号</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-container">
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号" 
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="input-group">
      <text class="input-label">密码</text>
      <input 
        class="input-field" 
        password 
        placeholder="请输入密码" 
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 登录按钮 -->
    <button class="login-btn" bindtap="onLogin" loading="{{loading}}">
      {{loading ? '登录中...' : '登录'}}
    </button>

    <!-- 注册链接 -->
    <view class="register-link">
      <text>还没有账号？</text>
      <text class="link-text" bindtap="navigateToRegister">立即注册</text>
    </view>
  </view>
</view>