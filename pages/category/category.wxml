<view class="container">
  <!-- 分类侧边栏 -->
  <scroll-view class="sidebar" scroll-y>
    <view 
      class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
      wx:for="{{categories}}" 
      wx:key="id"
      bindtap="switchCategory"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 商品列表 -->
  <scroll-view class="content" scroll-y>
    <view class="banner">
      <image src="{{currentCategoryData.banner}}" class="banner-image" mode="aspectFill" />
    </view>

    <view class="sub-categories">
      <view 
        class="sub-category" 
        wx:for="{{currentCategoryData.subCategories}}" 
        wx:key="id"
        bindtap="onSubCategoryClick"
        data-id="{{item.id}}"
      >
        <image src="{{item.image}}" class="sub-category-image" />
        <text class="sub-category-name">{{item.name}}</text>
      </view>
    </view>

    <view class="product-section">
      <view class="section-header">
        <text class="section-title">热门商品</text>
      </view>
      <view class="product-grid">
        <view 
          class="product-card" 
          wx:for="{{currentCategoryData.products}}" 
          wx:key="id"
          bindtap="onProductClick"
          data-id="{{item.id}}"
        >
          <image src="{{item.image}}" class="product-image" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <view class="price-section">
              <text class="current-price">¥{{item.price}}</text>
              <text class="original-price">¥{{item.originalPrice}}</text>
            </view>
            <text class="sales">已售{{item.sales}}件</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>