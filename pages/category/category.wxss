.container {
  display: flex;
  height: 100vh;
  background: #f8f8f8;
}

.sidebar {
  width: 100px;
  background: white;
}

.category-item {
  padding: 20px 10px;
  text-align: center;
  font-size: 13px;
  color: #4E5969;
  border-left: 3px solid transparent;
}

.category-item.active {
  color: #19aecc;
  background: #e6f7ff;
  border-left-color: #19aecc;
  font-weight: bold;
}

.content {
  flex: 1;
  padding: 10px;
}

.banner {
  height: 100px;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15px;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.sub-categories {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}

.sub-category {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  padding: 10px;
  border-radius: 8px;
}

.sub-category-image {
  width: 40px;
  height: 40px;
  margin-bottom: 5px;
}

.sub-category-name {
  font-size: 11px;
  color: #4E5969;
}

.product-section {
  background: white;
  padding: 15px;
  border-radius: 8px;
}

.section-header {
  margin-bottom: 15px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D2129;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.product-card {
  background: #f8f8f8;
  border-radius: 8px;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 120px;
}

.product-info {
  padding: 8px;
}

.product-name {
  font-size: 12px;
  color: #1D2129;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 5px;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 3px;
}

.current-price {
  font-size: 14px;
  color: #F53F3F;
  font-weight: bold;
}

.original-price {
  font-size: 10px;
  color: #86909C;
  text-decoration: line-through;
}

.sales {
  font-size: 10px;
  color: #86909C;
}