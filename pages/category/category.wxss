/* 分类页面样式优化 */
.container {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

/* 侧边栏样式 */
.sidebar {
  width: 90px;
  background: #ffffff;
  box-shadow: 2px 0 4px rgba(0,0,0,0.05);
}

.category-item {
  padding: 20px 8px;
  text-align: center;
  font-size: 13px;
  color: #666666;
  border-left: 3px solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

.category-item.active {
  color: #19aecc;
  background: linear-gradient(90deg, #e6f7ff, #ffffff);
  border-left-color: #19aecc;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 16px;
  background: #19aecc;
  border-radius: 0 2px 2px 0;
}

/* 内容区域样式 */
.content {
  flex: 1;
  padding: 12px;
  background: #f5f5f5;
}

/* 横幅广告 */
.banner {
  height: 120px;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.banner-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 子分类网格 */
.sub-categories {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}

.sub-category {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  padding: 12px 8px;
  border-radius: 12px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.04);
  transition: transform 0.2s ease;
}

.sub-category:active {
  transform: scale(0.98);
}

.sub-category-image {
  width: 44px;
  height: 44px;
  margin-bottom: 6px;
  border-radius: 8px;
  object-fit: cover;
}

.sub-category-name {
  font-size: 11px;
  color: #333333;
  font-weight: 500;
  text-align: center;
  line-height: 1.2;
}

/* 商品区域 */
.product-section {
  background: white;
  padding: 16px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.section-header {
  margin-bottom: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1D2129;
}

.section-more {
  font-size: 12px;
  color: #19aecc;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.product-card {
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: transform 0.2s ease;
}

.product-card:active {
  transform: translateY(2px);
}

.product-image {
  width: 100%;
  height: 140px;
  object-fit: cover;
  background: #f8f9fa;
}

.product-info {
  padding: 10px;
}

.product-name {
  font-size: 13px;
  color: #1D2129;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8px;
  line-height: 1.4;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}

.current-price {
  font-size: 15px;
  color: #F53F3F;
  font-weight: bold;
}

.original-price {
  font-size: 11px;
  color: #86909C;
  text-decoration: line-through;
}

.sales {
  font-size: 11px;
  color: #86909C;
}

/* 空状态提示 */
.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #999;
  font-size: 14px;
}

.empty-state image {
  width: 80px;
  height: 80px;
  margin-bottom: 12px;
  opacity: 0.5;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
  color: #19aecc;
  font-size: 13px;
}
