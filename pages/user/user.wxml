<view class="container">
  <!-- 用户信息头部 -->
 <view class="user-header">
  <view class="user-profile" bindtap="onWxFirstLogin">
    <image class="avatar" src="{{avatarUrl  || 'https://via.placeholder.com/100x100/19aecc/ffffff?text=用户'}}" />
    <view class="user-info">
      <text class="username">{{userInfo.name || userInfo.nickname || '点击登录'}}</text>
      <text class="user-level" wx:if="{{userInfo.level}}">{{userInfo.level}}</text>
    </view>
  </view>
</view>



  <!-- 订单状态 -->
  <view class="order-status">
    <view class="status-header">
      <text class="title">我的订单</text>
      <text class="view-all" bindtap="viewAllOrders">查看全部 ></text>
    </view>
    <view class="status-items">
      <view class="status-item" bindtap="viewOrders" data-status="1">
        <view class="status-icon-wrapper">
          <image src="/images/order/order-pending.svg" class="status-icon" />
          <view class="badge-wrapper" wx:if="{{orderCounts.pending > 0}}">
            <text class="badge">{{orderCounts.pending}}</text>
          </view>
        </view>
        <text class="status-text">待付款</text>
      </view>
      <view class="status-item" bindtap="viewOrders" data-status="2">
        <view class="status-icon-wrapper">
          <image src="/images/order/order-shipping.svg" class="status-icon" />
          <view class="badge-wrapper" wx:if="{{orderCounts.shipping > 0}}">
            <text class="badge">{{orderCounts.shipping}}</text>
          </view>
        </view>
        <text class="status-text">待发货</text>
      </view>
      <view class="status-item" bindtap="viewOrders" data-status="3">
        <view class="status-icon-wrapper">
          <image src="/images/order/order-delivered.svg" class="status-icon" />
          <view class="badge-wrapper" wx:if="{{orderCounts.delivered > 0}}">
            <text class="badge">{{orderCounts.delivered}}</text>
          </view>
        </view>
        <text class="status-text">待收货</text>
      </view>
      <view class="status-item" bindtap="viewOrders" data-status="4">
        <view class="status-icon-wrapper">
          <image src="/images/order/order-completed.svg" class="status-icon" />
          <view class="badge-wrapper" wx:if="{{orderCounts.completed > 0}}">
            <text class="badge">{{orderCounts.completed}}</text>
          </view>
        </view>
        <text class="status-text">已完成</text>
      </view>
      <view class="status-item" bindtap="viewOrders" data-status="5">
        <view class="status-icon-wrapper">
          <image src="/images/order/order-after-sale.svg" class="status-icon" />
          <view class="badge-wrapper" wx:if="{{orderCounts.afterSale > 0}}">
            <text class="badge">{{orderCounts.afterSale}}</text>
          </view>
        </view>
        <text class="status-text">售后</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/service/service">
      <image src="/images/icon-service.png" class="menu-icon" />
      <text>客服中心</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/settings/settings">
      <image src="/images/icon-settings.png" class="menu-icon" />
      <text>设置</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="logout">
      <image src="https://via.placeholder.com/40x40/19aecc/ffffff?text=🚪" class="menu-icon" />
      <text>退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>


  <!-- 用户信息填写半页面 -->
  <view class="user-info-form {{showUserInfoForm ? 'show' : ''}}">
    <view class="form-overlay" catchtap="closeUserInfoForm"></view>
    <view class="form-content">
      <view class="form-header">
        <text class="form-title">请登录</text>
        <view class="form-close" bindtap="closeUserInfoForm">×</view>
      </view>
      
      <view class="form-body">
        <!-- 头像选择区域 -->
        <view class="avatar-section">
          <text class="section-label">头像</text>
          <view class="avatar-picker">
            <image class="avatar-preview" src="{{tempAvatar || uploadedAvatarUrl || 'https://via.placeholder.com/100x100/19aecc/ffffff?text=头像'}}" />
            <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
              选择头像
            </button>
          </view>
        </view>

        <!-- 昵称输入区域 -->
        <view class="nickname-section">
          <text class="section-label">昵称</text>
          <input
            type="nickname"
            class="nickname-input"
            placeholder="请输入昵称"
            placeholder-class="placeholder"
            value="{{tempNickname}}"
            bindinput="onNicknameInput"
          />
        </view>

        <!-- 提交按钮 - 先进行登录，再触发手机号授权 -->
        <button 
          class="submit-btn" 
          bindtap="submitUserInfo"
        >
          登录
        </button>
        
        <text class="form-tip">授权后我们将获取您的头像、昵称</text>
      </view>
    </view>
  </view>

  <!-- 手机号授权弹窗 -->
  <view class="phone-auth-popup {{showPhoneAuthPopup ? 'show' : ''}}">
    <view class="popup-overlay" catchtap="onGetPhoneNumber"></view>
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">手机号授权</text>
        <view class="popup-close" bindtap="onGetPhoneNumber">×</view>
      </view>
      
      <view class="popup-body">
        <text class="popup-desc">为了完成登录，请授权获取您的手机号</text>
        
        <button 
          class="auth-button" 
          open-type="getPhoneNumber" 
          bindgetphonenumber="onGetPhoneNumber"
        >
          授权手机号
        </button>
        
        <button 
          class="auth-cancel-button" 
          bindtap="onGetPhoneNumber"
        >
          拒绝授权
        </button>
      </view>
    </view>
  </view>
</view>
