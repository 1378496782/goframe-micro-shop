.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20px;
}

.user-header {
  background: linear-gradient(135deg, #19aecc, #2c8cf0);
  padding: 30px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
}

.user-profile {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.3);
  margin-right: 15px;
}

.user-info {
  flex: 1;
}

.username {
  font-size: 18px;
  font-weight: bold;
  display: block;
  margin-bottom: 5px;
}

.user-level {
  font-size: 12px;
  background: rgba(255, 255, 255, 0.2);
  padding: 2px 8px;
  border-radius: 10px;
}

.auth-tip {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 4px 10px;
  border-radius: 15px;
  margin-top: 5px;
  display: inline-block;
  border: 1px solid rgba(255, 255, 255, 0.5);
}

.login-btn {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: 20px;
  padding: 8px 16px;
  font-size: 12px;
}

.order-status {
  background: white;
  margin: 15px;
  border-radius: 8px;
  padding: 15px;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #1D2129;
}

.view-all {
  font-size: 12px;
  color: #86909C;
}

.status-items {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.status-icon {
  width: 24px;
  height: 24px;
  margin-bottom: 5px;
}

.status-item text {
  font-size: 12px;
  color: #4E5969;
}

.badge {
  position: absolute;
  top: -5px;
  right: -5px;
  background: #F53F3F;
  color: white;
  font-size: 10px;
  padding: 1px 4px;
  border-radius: 8px;
  min-width: 12px;
  text-align: center;
}

.menu-list {
  background: white;
  margin: 15px;
  border-radius: 8px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 20px;
  height: 20px;
  margin-right: 15px;
}

.menu-item text {
  flex: 1;
  font-size: 14px;
  color: #1D2129;
}

.arrow {
  color: #86909C;
  font-size: 14px;
}

.logout-btn {
  margin: 15px;
  background: #F53F3F;
  color: white;
  border-radius: 6px;
}

/* 微信登录弹窗样式 */
.wx-login-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.wx-login-popup.show {
  visibility: visible;
  opacity: 1;
}

.wx-login-content {
  background-color: #fff;
  border-radius: 16px 16px 0 0;
  height: 50vh;
  padding: 20px;
  position: relative;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.wx-login-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid #f0f0f0;
}

.wx-login-title {
  font-size: 18px;
  font-weight: bold;
  color: #1D2129;
}

.wx-login-close {
  font-size: 24px;
  color: #86909C;
  padding: 5px;
}

.wx-login-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 0;
}

.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.preview-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-bottom: 10px;
  border: 2px solid #19aecc;
}

.upload-text {
  font-size: 14px;
  color: #86909C;
}

.nickname-input {
  width: 100%;
  margin-bottom: 20px;
}

.input-field {
  height: 44px;
  background: #f8f8f8;
  border-radius: 8px;
  padding: 0 15px;
  font-size: 16px;
  border: 1px solid #E5E6EB;
  width: 100%;
  box-sizing: border-box;
}

.wx-login-btn {
  background: #07c160;
  color: white;
  border-radius: 8px;
  height: 48px;
  line-height: 48px;
  font-size: 16px;
  font-weight: 500;
  width: 100%;
  margin-top: 10px;
}

.placeholder {
  color: #86909C;
  font-size: 14px;
}

/* 昵称输入工具栏样式 */
.nickname-toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #f5f5f5;
  padding: 10px;
  display: flex;
  justify-content: flex-end;
  border-top: 1px solid #e0e0e0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1000;
}

.nickname-toolbar.show {
  transform: translateY(0);
}

.toolbar-btn {
  background: #19aecc;
  color: white;
  font-size: 14px;
  padding: 8px 16px;
  border-radius: 4px;
  margin-left: 10px;
  border: none;
  line-height: 1.5;
  height: auto;
}