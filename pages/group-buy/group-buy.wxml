<view class="container" wx:if="{{!loading}}">
  <!-- 商品图片 -->
  <view class="product-image-section">
    <image src="{{groupBuyInfo.mainImage}}" class="product-image" mode="aspectFit" />
  </view>

  <!-- 商品信息 -->
  <view class="product-info">
    <text class="product-name">{{groupBuyInfo.name}}</text>
    <text class="product-desc">{{groupBuyInfo.description}}</text>
    
    <view class="price-section">
      <text class="group-price">¥{{groupPriceFormatted}}</text>
      <text class="original-price">¥{{originalPriceFormatted}}</text>
    </view>

    <view class="group-info">
      <text class="info-text">{{groupBuyInfo.groupCount}}人团</text>
      <text class="info-text">截止时间：{{groupBuyInfo.endTime}}</text>
    </view>
  </view>

  <!-- 拼团进度 -->
  <view class="progress-section">
    <view class="progress-header">
      <text class="progress-title">拼团进度</text>
      <text class="progress-text">{{groupBuyInfo.currentParticipants}}/{{groupBuyInfo.groupCount}}人</text>
    </view>
    
    <progress 
      class="progress-bar" 
      percent="{{groupProgress}}" 
      stroke-width="8" 
      active-color="#19aecc" 
      backgroundColor="#f0f0f0" 
    />
    
    <text class="progress-percent">{{groupProgress}}%</text>
  </view>

  <!-- 参团用户列表 -->
  <view class="participants-section" wx:if="{{participants.length > 0}}">
    <text class="section-title">已参团用户</text>
    <scroll-view class="participants-list" scroll-x="true">
      <view class="participant-item" wx:for="{{participants}}" wx:key="id">
        <image src="{{item.avatar}}" class="participant-avatar" />
        <text class="participant-name">{{item.nickname}}</text>
        <text class="participant-time">{{item.joinTime}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 拼团规则 -->
  <view class="rules-section">
    <text class="section-title">拼团规则</text>
    <text class="rules-text">{{groupBuyInfo.rules}}</text>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 底部操作栏 -->
<view class="footer" wx:if="{{!loading}}">
  <button 
    class="join-btn" 
    bindtap="onJoinGroup"
    disabled="{{currentUserJoined || groupBuyInfo.currentParticipants >= groupBuyInfo.groupCount}}"
  >
    {{currentUserJoined ? '已参团' : groupBuyInfo.currentParticipants >= groupBuyInfo.groupCount ? '已满团' : '立即参团'}}
  </button>
  
  <button class="share-btn" open-type="share">
    <text class="icon">📤</text>
    <text>邀请好友</text>
  </button>
</view>