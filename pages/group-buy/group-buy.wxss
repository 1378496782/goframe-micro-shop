/* 页面容器 */
.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 120rpx; /* 为底部按钮留出空间 */
}

/* 商品图片区域 */
.product-image-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.product-image {
  width: 400rpx;
  height: 300rpx;
  border-radius: 12rpx;
}

/* 商品信息 */
.product-info {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
  display: block;
  margin-bottom: 16rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.group-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #F53F3F;
}

.original-price {
  font-size: 24rpx;
  color: #86909C;
  text-decoration: line-through;
}

.group-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 24rpx;
  color: #4E5969;
}

/* 进度条区域 */
.progress-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1D2129;
}

.progress-text {
  font-size: 24rpx;
  color: #19aecc;
}

.progress-bar {
  margin-bottom: 12rpx;
}

.progress-percent {
  font-size: 24rpx;
  color: #19aecc;
  text-align: center;
  display: block;
}

/* 参团用户区域 */
.participants-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1D2129;
  margin-bottom: 20rpx;
  display: block;
}

.participants-list {
  white-space: nowrap;
}

.participant-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
  min-width: 120rpx;
}

.participant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.participant-name {
  font-size: 22rpx;
  color: #1D2129;
  margin-bottom: 4rpx;
  text-align: center;
}

.participant-time {
  font-size: 18rpx;
  color: #86909C;
  text-align: center;
}

/* 规则区域 */
.rules-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.rules-text {
  font-size: 24rpx;
  color: #4E5969;
  line-height: 1.6;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #86909C;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.join-btn {
  flex: 2;
  background: #19aecc;
  color: white;
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.join-btn[disabled] {
  background: #C9CDD4;
  color: white;
}

.share-btn {
  flex: 1;
  background: #FFB300;
  color: white;
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.icon {
  font-size: 24rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .product-image {
    width: 300rpx;
    height: 225rpx;
  }
  
  .footer {
    padding: 16rpx 20rpx;
  }
  
  .join-btn,
  .share-btn {
    height: 70rpx;
    line-height: 70rpx;
    font-size: 26rpx;
  }
}