<view class="register-container">
  <!-- 头部标题 -->
  <view class="header">
    <text class="title">用户注册</text>
    <text class="subtitle">创建您的账号</text>
  </view>

  <!-- 注册表单 -->
  <view class="form-container">
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号" 
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="input-group">
      <text class="input-label">验证码</text>
      <view class="code-input-group">
        <input 
          class="input-field code-input" 
          type="number" 
          placeholder="请输入验证码" 
          placeholder-class="placeholder"
          value="{{code}}"
          bindinput="onCodeInput"
          maxlength="6"
        />
        <button 
          class="send-code-btn" 
          bindtap="onSendCode" 
          disabled="{{codeCountdown > 0}}"
        >
          {{codeCountdown > 0 ? codeCountdown + 's后重发' : '发送验证码'}}
        </button>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">密码</text>
      <input 
        class="input-field" 
        password 
        placeholder="请设置密码（6-20位）" 
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="input-group">
      <text class="input-label">确认密码</text>
      <input 
        class="input-field" 
        password 
        placeholder="请再次输入密码" 
        placeholder-class="placeholder"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <!-- 注册协议 -->
    <view class="agreement">
      <checkbox checked="{{agreed}}" bindtap="onToggleAgreement" />
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="onViewAgreement">《用户协议》</text>
    </view>

    <!-- 注册按钮 -->
    <button class="register-btn" bindtap="onRegister" loading="{{loading}}">
      {{loading ? '注册中...' : '注册'}}
    </button>

    <!-- 登录链接 -->
    <view class="login-link">
      <text>已有账号？</text>
      <text class="link-text" bindtap="navigateToLogin">立即登录</text>
    </view>
  </view>
</view>