<view class="container">
  <!-- 顶部标签栏 -->
  <view class="tab-bar" wx:if="{{showTabs}}">
    <view 
      wx:for="{{tabs}}" 
      wx:key="id" 
      class="tab-item {{activeTab === item.id ? 'active' : ''}}"
      bindtap="switchTab"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
      <view class="tab-line" wx:if="{{activeTab === item.id}}"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view 
    class="order-list-container" 
    scroll-y 
    enable-back-to-top 
    bindscrolltolower="onReachBottom"
  >
    <view class="order-list">
      <!-- 订单项 -->
      <view 
        wx:for="{{orderList}}" 
        wx:key="id" 
        class="order-item grid-item"
      >
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="order-number">订单号：{{item.order_number || item.id}}</view>
          <view class="order-status">{{item.statusText}}</view>
        </view>
        
        <!-- 订单商品列表 -->
        <view class="goods-list">
          <view 
            wx:for="{{item.goods}}" 
            wx:for-item="goods" 
            wx:key="id"
            class="goods-item"
          >
            <image class="goods-image" src="{{goods.image || goods.goods_pic_url}}" mode="aspectFill" />
            <view class="goods-info">
              <view class="goods-name">{{goods.name || goods.goods_name}}</view>
              <view class="goods-spec">{{goods.spec || goods.goods_brand || '默认规格'}}</view>
              <view class="goods-price-count">
                <text class="goods-price">¥{{goods.price || goods.goods_price}}</text>
                <text class="goods-count">x{{goods.quantity || goods.count || 1}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 订单底部 -->
        <view class="order-footer">
          <view class="order-time">{{item.createTime}}</view>
          <view class="order-total">
            <text>共{{(item.goods && item.goods.length) || 0}}件商品</text>
            <text class="total-price">合计：¥{{item.totalAmount || item.price || 0}}</text>
          </view>
          
          <!-- 订单操作按钮 -->
          <view class="order-actions">
            <!-- 待付款状态 -->
            <block wx:if="{{item.status === 1}}">
              <button 
                class="action-btn cancel" 
                catchtap="cancelOrder" 
                data-id="{{item.id}}"
              >取消订单</button>
              <button 
                class="action-btn primary" 
                catchtap="goPay" 
                data-id="{{item.id}}"
                data-number="{{item.order_number}}"
                data-index="{{index}}"
              >去支付</button>
            </block>
            
            <!-- 待发货状态 -->
            <block wx:elif="{{item.status === 2}}">
            </block>
            
            <!-- 待收货状态 -->
            <block wx:elif="{{item.status === 3}}">
              <button 
                class="action-btn default" 
                catchtap="viewLogistics" 
                data-id="{{item.id}}"
              >查看物流</button>
              <button 
                class="action-btn primary" 
                catchtap="confirmReceive" 
                data-id="{{item.id}}"
              >确认收货</button>
            </block>
            
            <!-- 已完成状态 -->
            <block wx:elif="{{item.status === 4}}">
              <button 
                class="action-btn primary" 
                catchtap="applyAfterSale" 
                data-id="{{item.id}}"
              >申请售后</button>
            </block>
            
            <!-- 售后状态 -->
            <block wx:elif="{{item.status === 5}}">
              <button 
                class="action-btn default" 
                catchtap="viewAfterSale" 
                data-id="{{item.id}}"
              >售后详情</button>
            </block>
          </view>
        </view>
      </view>
      
      <!-- 空状态 - 显示"没有订单"提示 -->
      <view class="empty-state" wx:if="{{orderList.length === 0 && !loading}}">
        <view class="empty-icon">
          <text class="empty-text">📦</text>
        </view>
        <view class="empty-message">
          <text>没有订单</text>
        </view>
        <view class="empty-sub-message">
          <text>您还没有任何订单</text>
        </view>
      </view>
      
      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading && page > 1}}">
        <text>加载中...</text>
      </view>
      
      <!-- 加载完毕 -->
      <view class="load-all" wx:if="{{!hasMore && orderList.length > 0 && !loading}}">
        <text>已加载全部订单</text>
      </view>
    </view>
  </scroll-view>
</view>