  padding: 20rpx 30rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.order-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.total-price {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
