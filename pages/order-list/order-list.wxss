/* 页面容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部标签栏 */
.tab-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  color: #19aecc;
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background-color: #19aecc;
  border-radius: 2rpx;
}

/* 订单列表容器 */
.order-list-container {
  flex: 1;
  width: 100%;
}

.order-list {
  padding: 20rpx;
}

/* 订单列表 - 列表布局 */
.order-list {
  padding: 20rpx;
}

/* 订单项 */
.order-item {
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 商品列表 */
.goods-list {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
}

.goods-item:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* 订单底部 */
.order-footer {
  padding: 20rpx 30rpx;
}

/* 订单操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.action-btn {
  margin-left: 20rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background-color: #ffffff;
}

.action-btn.default {
  color: #666;
  border: 1rpx solid #ddd;
}

.action-btn.primary {
  color: #ffffff;
  background-color: #19aecc;
  border: 1rpx solid #19aecc;
}

.action-btn.cancel {
  color: #666;
  border: 1rpx solid #ddd;
}

