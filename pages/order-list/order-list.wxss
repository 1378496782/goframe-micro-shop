  margin-bottom: 10rpx;
}

.goods-price-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
}

/* 订单底部 */
