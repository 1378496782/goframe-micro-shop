/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  width: 100%;
}

.empty-icon {
  margin-bottom: 20rpx;
  font-size: 120rpx;
  color: #ccc;
}

.empty-message {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.empty-sub-message {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80rpx;
  font-size: 24rpx;
  color: #999;
}

/* 加载完毕 */
.load-all {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80rpx;
  font-size: 24rpx;
  color: #999;
}

/* 空白订单项 */
.empty-order-item {
  margin: 0;
  width: auto;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #66CCFF;
  border-radius: 12rpx;
  background-color: #f9f9f9;
}

/* 空白商品图片 */
.empty-goods-image {
  width: 100%;
  height: 160rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

/* 空白商品信息 */
.empty-goods-info {
  width: 100%;
}

.empty-goods-name,
.empty-goods-spec,
.empty-goods-price {
  height: 30rpx;
  background-color: #f0f0f0;
  margin-bottom: 10rpx;
  border-radius: 4rpx;
}

.empty-goods-name {
  width: 80%;
}

.empty-goods-spec {
  width: 60%;
}

.empty-goods-price {
  width: 40%;
  height: 40rpx;
}

/* 空白操作按钮 */
.empty-order-actions {
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
}

.empty-action-btn {
  width: 120rpx;
  height: 50rpx;
  background-color: #f0f0f0;
  border-radius: 25rpx;
  margin: 0 5rpx;
}

.empty-action-btn.primary {
  background-color: #e0f0f5;
}

/* 空白订单提示 */
.empty-order-hint {
  grid-column: 1 / -1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #999;
  border-top: 1rpx dashed #e0e0e0;
  margin-top: 20rpx;
}

