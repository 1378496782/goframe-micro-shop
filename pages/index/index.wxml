<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索商品" 
      placeholder-class="placeholder"
      bindinput="onSearchInput"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="3000">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image src="{{item.image}}" class="banner-image" mode="aspectFill" bindtap="onBannerClick" data-url="{{item.url}}"/>
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <view class="category-nav">
    <view 
      class="category-item" 
      wx:for="{{categories}}" 
      wx:key="id"
      bindtap="onCategoryClick"
      data-id="{{item.id}}"
    >
      <image src="{{item.icon}}" class="category-icon"/>
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

