  <!-- 推荐商品 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门推荐</text>
      <text class="section-more" bindtap="onViewMore">查看更多 ></text>
    </view>
    <view class="product-list">
      <view 
        class="product-item" 
        wx:for="{{products}}" 
        wx:key="id"
        bindtap="onProductClick"
        data-id="{{item.id}}"
      >
        <image src="{{item.mainImage || 'https://via.placeholder.com/200x200?text=商品图片'}}" class="product-image" mode="aspectFill"/>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="price-section">
            <text class="current-price">¥{{item.priceFormatted}}</text>
          </view>
          <text class="sales">已售{{item.sale || 0}}件</text>
        </view>
      </view>
    </view>
  </view>
</view>