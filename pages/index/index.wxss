.container {
  padding: 10px;
  background: #f8f8f8;
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 15px;
}

.search-input {
  flex: 1;
  height: 36px;
  background: white;
  border-radius: 18px;
  padding: 0 15px;
  font-size: 14px;
}

.placeholder {
  color: #86909C;
}

.search-btn {
  background: #19aecc;
  color: white;
  border-radius: 18px;
  padding: 0 15px;
  height: 36px;
  line-height: 36px;
  font-size: 14px;
}

.banner-swiper {
  height: 150px;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15px;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.category-nav {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15px;
  background: white;
  padding: 15px;
  border-radius: 8px;
  margin-bottom: 15px;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  margin-bottom: 5px;
}

.category-name {
  font-size: 12px;
  color: #4E5969;
}

.section {
  background: white;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 15px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D2129;
}

.section-more {
  font-size: 12px;
  color: #86909C;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.product-item {
  background: #f8f8f8;
  border-radius: 8px;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 120px;
}

.product-info {
  padding: 8px;
}

.product-name {
  font-size: 12px;
  color: #1D2129;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 5px;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 3px;
}

.current-price {
  font-size: 14px;
  color: #F53F3F;
  font-weight: bold;
}

.original-price {
  font-size: 10px;
  color: #86909C;
  text-decoration: line-through;
}

.sales {
  font-size: 10px;
  color: #86909C;
}