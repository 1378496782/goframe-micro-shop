grpc:
  name:             "goods"
  address:          ":31004"
  logger:
    path: "./log" # 日志文件路径。默认为空，表示关闭，仅输出到终端
    file: "{Y-m-d}.log" # 日志文件格式。默认为"{Y-m-d}.log"
    prefix: "公众号：王中阳：goods-service" # 日志内容输出前缀。方便在所有日志行里一眼认出是我们这个服务产生的。
    level: "all" # 日志输出级别
    stdout: true  # 日志是否同时输出到终端。默认true
    rotateSize: 104857600   # 100MB切割日志文件
    rotateBackupLimit: 7    # 保留7天日志
    # ctxKeys 告诉日志组件从 context 中提取指定键的值
    ctxKeys: [ "traceId" ]    # 自动记录链路追踪ID 自定义Context上下文变量名称，自动打印Context的变量到日志中
    timeFormat: "2006-01-02 15:04:05.000" # 精确到毫秒

database:
  default:
    link:  "mysql:root:root@tcp(127.0.0.1:3306)/goods"
    debug:


etcd:
  address: "127.0.0.1:2379"

# Redis配置
redis:
  # 商品服务专用配置
  goods:
    address: "127.0.0.1:6379"
    db: 1  # 使用单独的db
    pass: ""
    idleTimeout: "600s"
    maxActive: 50
    idle: 10
    connectTimeout: "5s"
    # 可以添加其他Redis配置参数

rabbitmq:
  default:
    host: "127.0.0.1"
    port: "5672"
    user: "root"
    password: "root"
    vhost: "/"
  exchange:
    user: "user_events"
    # 接收order服务发来的优惠券确认请求
    couponConfirmExchange: "coupon.confirm.exchange"
    # 用于向order服务发送确认结果（Direct Exchange）
    couponConfirmResultExchange: "coupon.confirm.result.exchange"
    goodsStockExchange: "goods.stock.exchange"
  queue:
    user:
      registered: "user_registered_queue"
    # 服务监听“优惠券确认请求”的队列
    couponConfirmRequestQueue: "coupon.confirm.request.queue"
    goodsStockQueue: "goods_stock_queue"
  routingKey:
    user:
      registered: "user.registered"
    # 服务绑定队列时用的 RoutingKey（匹配order服务发来的消息）
    couponConfirmRequest: "coupon.confirm.request"
    # 服务发送“确认结果”给服务order时用的 RoutingKey
    couponConfirmResult: "coupon.confirm.result"
    goodsStock: "goods.stock"