<view class="container">
  <view class="header">
    <text class="title">网络请求测试</text>
  </view>

  <view class="button-group">
    <button class="test-btn" bindtap="onTestRequest" loading="{{loading}}">
      测试登录接口
    </button>
    
    <button class="test-btn" bindtap="onTestPing" loading="{{loading}}">
      测试网络连通性
    </button>
  </view>

  <view class="result" wx:if="{{result}}">
    <text class="result-title">请求结果:</text>
    <text class="result-content">{{result}}</text>
  </view>
</view>