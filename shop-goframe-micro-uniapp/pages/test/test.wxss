.container {
  padding: 20px;
}

.header {
  text-align: center;
  margin-bottom: 30px;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #1D2129;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 15px;
  margin-bottom: 30px;
}

.test-btn {
  background: #19aecc;
  color: white;
  border-radius: 8px;
  height: 44px;
  line-height: 44px;
}

.result {
  background: #f8f8f8;
  border-radius: 8px;
  padding: 15px;
  margin-top: 20px;
}

.result-title {
  display: block;
  font-size: 14px;
  font-weight: bold;
  color: #4E5969;
  margin-bottom: 10px;
}

.result-content {
  font-size: 12px;
  color: #86909C;
  word-break: break-all;
}