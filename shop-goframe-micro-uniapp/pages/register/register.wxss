.register-container {
  padding: 40px 20px;
  background: #f8f8f8;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40px;
}

.title {
  display: block;
  font-size: 24px;
  font-weight: bold;
  color: #1D2129;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: #86909C;
}

.form-container {
  background: white;
  border-radius: 12px;
  padding: 30px 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 25px;
}

.input-label {
  display: block;
  font-size: 14px;
  color: #4E5969;
  margin-bottom: 8px;
  font-weight: 500;
}

.input-field {
  height: 44px;
  background: #f8f8f8;
  border-radius: 8px;
  padding: 0 15px;
  font-size: 16px;
  border: 1px solid #E5E6EB;
}

.input-field:focus {
  border-color: #19aecc;
}

.placeholder {
  color: #86909C;
  font-size: 14px;
}

.code-input-group {
  display: flex;
  align-items: center;
  gap: 10px;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  background: #19aecc;
  color: white;
  border-radius: 6px;
  padding: 0 12px;
  height: 36px;
  line-height: 36px;
  font-size: 12px;
  white-space: nowrap;
}

.send-code-btn:disabled {
  background: #CCCCCC;
}

.agreement {
  display: flex;
  align-items: center;
  margin: 20px 0;
  font-size: 12px;
  color: #86909C;
}

.agreement-text {
  margin-left: 5px;
}

.agreement-link {
  color: #19aecc;
  margin-left: 3px;
}

.register-btn {
  background: #19aecc;
  color: white;
  border-radius: 8px;
  height: 48px;
  line-height: 48px;
  font-size: 16px;
  font-weight: 500;
}

.register-btn:active {
  background: #158ea8;
}

.login-link {
  text-align: center;
  margin-top: 25px;
  font-size: 14px;
  color: #86909C;
}

.link-text {
  color: #19aecc;
  margin-left: 5px;
}