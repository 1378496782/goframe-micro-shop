<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">拼团砍价专区</text>
    <text class="page-subtitle">邀请好友一起享优惠</text>
  </view>

  <!-- 拼团列表 -->
  <view class="group-buy-list">
    <view 
      class="group-buy-item" 
      wx:for="{{groupBuyList}}" 
      wx:key="id"
      bindtap="onGroupBuyClick"
      data-id="{{item.id}}"
    >
      <!-- 商品图片 -->
      <image src="{{item.mainImage}}" class="item-image" mode="aspectFill" />
      
      <!-- 商品信息 -->
    <view class="item-info">
      <text class="item-name">{{item.name}}</text>
        
        <!-- 价格信息 -->
        <view class="price-info">
          <text class="group-price">¥{{item.groupPriceFormatted}}</text>
          <text class="original-price">¥{{item.originalPriceFormatted}}</text>
        </view>
        
        <!-- 拼团信息 -->
        <view class="group-info">
          <text class="group-count">{{item.groupCount}}人团</text>
          <text class="participants">{{item.participants}}人已参与</text>
        </view>
        
        <!-- 进度条 -->
        <view class="progress-section">
          <progress 
            class="progress-bar" 
            percent="{{item.progress}}" 
            stroke-width="6" 
            active-color="#19aecc" 
            backgroundColor="#f0f0f0" 
          />
          <text class="progress-text">{{item.currentParticipants}}/{{item.groupCount}}人</text>
        </view>
        
        <!-- 时间信息 -->
        <view class="time-info">
          <text class="time-left">剩余时间：{{item.timeLeft}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <button 
      class="load-more-btn" 
      bindtap="onLoadMore"
      loading="{{loadingMore}}"
    >
      {{loadingMore ? '加载中...' : '加载更多'}}
    </button>
  </view>

  <view class="no-more" wx:if="{{!hasMore && groupBuyList.length > 0}}">
    <text class="no-more-text">没有更多了</text>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading && groupBuyList.length === 0}}">
  <text class="loading-text">加载中...</text>
</view>

<!-- 空状态 -->
<view class="empty-container" wx:if="{{!loading && groupBuyList.length === 0}}">
  <image src="/images/empty-group.png" class="empty-image" />
  <text class="empty-text">暂无拼团活动</text>
  <text class="empty-desc">敬请期待更多优惠活动</text>
</view>