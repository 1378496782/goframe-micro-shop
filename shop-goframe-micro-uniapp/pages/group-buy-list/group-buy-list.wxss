/* 页面容器 */
.container {
  padding: 20rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1D2129;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #86909C;
}

/* 拼团列表 */
.group-buy-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.group-buy-item {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.group-buy-item:active {
  transform: scale(0.98);
}

.item-image {
  width: 100%;
  height: 300rpx;
}

.item-info {
  padding: 24rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1D2129;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 价格信息 */
.price-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #F53F3F;
}

.original-price {
  font-size: 24rpx;
  color: #86909C;
  text-decoration: line-through;
}

/* 拼团信息 */
.group-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-count {
  font-size: 24rpx;
  color: #19aecc;
  background: rgba(25, 174, 204, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

.participants {
  font-size: 22rpx;
  color: #86909C;
}

/* 进度条 */
.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
}

.progress-text {
  font-size: 22rpx;
  color: #19aecc;
  min-width: 80rpx;
  text-align: right;
}

/* 时间信息 */
.time-info {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.time-left {
  font-size: 22rpx;
  color: #FFB300;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-btn {
  background: #19aecc;
  color: white;
  border-radius: 50rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 26rpx;
  padding: 0 40rpx;
  border: none;
}

.load-more-btn[loading] {
  background: #C9CDD4;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #86909C;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}

.loading-text {
  font-size: 28rpx;
  color: #86909C;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  text-align: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #86909C;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #C9CDD4;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .item-image {
    height: 250rpx;
  }
  
  .item-name {
    font-size: 26rpx;
  }
  
  .group-price {
    font-size: 28rpx;
  }
  
  .original-price {
    font-size: 22rpx;
  }
}

/* 下拉刷新样式 */
.wx-pull-refresh {
  background: #f8f8f8;
}