<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">全部商品</text>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view 
      class="product-item" 
      wx:for="{{products}}" 
      wx:key="id"
      bindtap="onProductClick"
      data-id="{{item.id}}"
    >
      <image src="{{item.mainImage || 'https://via.placeholder.com/200x200?text=商品图片'}}" class="product-image" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="price-section">
          <text class="current-price">¥{{item.priceFormatted}}</text>
        </view>
        <text class="sales">已售{{item.sale || 0}}件</text>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{!refreshing}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">没有更多商品了</text>
    <text wx:else>上拉加载更多</text>
  </view>

  <!-- 下拉刷新提示 -->
  <view class="refresh-indicator" wx:if="{{refreshing}}">
    <text>刷新中...</text>
  </view>
</view>